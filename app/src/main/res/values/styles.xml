<resources>

    <style name="SpaceStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="DialogStyle">
        <!--是否显示Title -->
        <item name="android:windowNoTitle">true</item>
        <!--Dialog中Window的背景颜色-->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!--Dialog背景颜色-->
        <item name="android:background">@android:color/transparent</item>
        <!--去除边框-->
        <item name="android:windowFrame">@null</item>
        <!--是否浮现在activity之上-->
        <item name="android:windowIsFloating">true</item>
        <!--是否半透明-->
        <item name="android:windowIsTranslucent">true</item>
        <!-- ActionMode 覆盖 Actionbar，不顶下来 -->
        <item name="windowActionModeOverlay">true</item>
        <!-- 遮挡物 -->
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="DialogStyle.Normal">
        <item name="android:windowMinWidthMinor">80%</item>
    </style>

    <style name="CircleStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TitleBarStyle">
        <item name="android:background">@color/colorPrimary</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="leftTitleColor">@color/white</item>
        <item name="titleColor">@color/white</item>
    </style>

    <style name="TitleBarStyle.Back">
        <item name="leftTitle">返回</item>
        <item name="leftIcon">@drawable/ic_back</item>
    </style>
</resources>